{
  "name": "@laborledger/database",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "prisma": "prisma --schema prisma/schema.prisma",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:validate": "prisma validate --schema prisma/schema.prisma",
    "seed:demo": "tsx src/seed-demo.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "argon2": "^0.41.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "prisma": "^6.10.1",
    "tsx": "^4.20.3"
  }
}
