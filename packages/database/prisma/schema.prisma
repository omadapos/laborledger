  vehicle                 Vehicle?                  @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([groupId], map: "labor_work_assignments_group_id_idx")
  @@index([companyId], map: "labor_work_assignments_company_id_idx")
  @@index([employeeId], map: "labor_work_assignments_employee_id_idx")
  @@index([shiftId], map: "labor_work_assignments_shift_id_idx")
  @@index([serviceClientId], map: "labor_work_assignments_service_client_id_idx")
  @@index([locationId], map: "labor_work_assignments_location_id_idx")
  @@index([status], map: "labor_work_assignments_status_idx")
  @@index([startedAt], map: "labor_work_assignments_started_at_idx")
  @@map("labor_work_assignments")
}
