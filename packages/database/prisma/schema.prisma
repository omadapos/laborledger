generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Group {
  id         String      @id @default(cuid())
  name       String
  status     GroupStatus @default(ACTIVE)
  suspendedAt DateTime?
  suspendedByUserId String?
  suspendedReason String?
  archivedAt DateTime?
  archivedByUserId String?
  archivedReason String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  companies  Company[]
  memberships GroupMembership[]
  invitations Invitation[]
  auditEvents AuditEvent[]
  serviceClients ServiceClient[]
  locations    Location[]
  employees    Employee[]
  supervisorAssignments SupervisorLocationAssignment[]
  scheduleTemplates ScheduleTemplate[]
  shiftGenerationBatches ShiftGenerationBatch[]
  shifts       Shift[]
  kiosks       Kiosk[]
  punchEvents  PunchEvent[]
  correctionRequests CorrectionRequest[]
  punchCorrections PunchCorrection[]
  weeklyPeriods WeeklyPeriod[]
  serviceCatalogItems ServiceCatalogItem[]
  vehicles       Vehicle[]
  workOrders     WorkOrder[]
  workOrderServiceLines WorkOrderServiceLine[]
  workOrderStatusHistory WorkOrderStatusHistory[]
  workOrderAssignments WorkOrderAssignment[]
  vehicleResponsibilityLogs VehicleResponsibilityLog[]
  workerScanEvents WorkerScanEvent[]
  serviceCompletions ServiceCompletion[]
  clientInvoices     ClientInvoice[]
  clientInvoiceLines ClientInvoiceLine[]
  clientInvoiceDeliveries ClientInvoiceDelivery[]
  laborWorkAssignments LaborWorkAssignment[]

  @@map("groups")
}

model Company {
  id                 String   @id @default(cuid())
  groupId            String
  name               String
  currencyCode       String   @default("USD")
  legalName          String?
  phone              String?
  billingEmail       String?
  primaryContactName String?
  addressLine1       String?
  addressLine2       String?
  city               String?
  stateRegion        String?
  postalCode         String?
  country            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  group        Group    @relation(fields: [groupId], references: [id], onDelete: Restrict)
  memberships  CompanyMembership[]
  invitations  Invitation[]
  auditEvents  AuditEvent[]
  serviceClients ServiceClient[]
  locations    Location[]
  employees    Employee[]
  employeeRates EmployeeRate[]
  clientLaborRates ClientLaborRate[]
  supervisorAssignments SupervisorLocationAssignment[]
  employeePinCredentials EmployeePinCredential[]
  scheduleTemplates ScheduleTemplate[]
  shiftGenerationBatches ShiftGenerationBatch[]
  shifts       Shift[]
  kiosks       Kiosk[]
  punchEvents  PunchEvent[]
  correctionRequests CorrectionRequest[]
  punchCorrections PunchCorrection[]
  weeklyPeriods WeeklyPeriod[]
  serviceCatalogItems ServiceCatalogItem[]
  vehicles       Vehicle[]
  workOrders     WorkOrder[]
  workOrderServiceLines WorkOrderServiceLine[]
  workOrderStatusHistory WorkOrderStatusHistory[]
  workOrderAssignments WorkOrderAssignment[]
  vehicleResponsibilityLogs VehicleResponsibilityLog[]
  workerScanEvents WorkerScanEvent[]
  serviceCompletions ServiceCompletion[]
  clientInvoices     ClientInvoice[]
  clientInvoiceLines ClientInvoiceLine[]
  clientInvoiceDeliveries ClientInvoiceDelivery[]
  activeSessions     Session[]
  laborWorkAssignments LaborWorkAssignment[]

  @@index([groupId], map: "companies_group_id_idx")
  @@unique([groupId, name], map: "companies_group_id_name_key")
  @@map("companies")
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  passwordHash       String
  fullName           String?
  globalRole         GlobalRole          @default(NONE)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  sessions           Session[]
  groupMemberships   GroupMembership[]
  companyMemberships CompanyMembership[]
  invitations        Invitation[]        @relation("InvitationUser")
  createdInvitations Invitation[]        @relation("InvitationCreatedBy")
  auditEvents        AuditEvent[]
  createdEmployeePins EmployeePinCredential[] @relation("EmployeePinCreatedBy")
  createdEmployeeRates EmployeeRate[]    @relation("EmployeeRateCreatedBy")
  createdClientLaborRates ClientLaborRate[] @relation("ClientLaborRateCreatedBy")
  assignedSupervisorLocations SupervisorLocationAssignment[] @relation("SupervisorAssignedBy")
  supervisorLocationAssignments SupervisorLocationAssignment[] @relation("LocationSupervisor")
  createdScheduleTemplates ScheduleTemplate[] @relation("ScheduleTemplateCreatedBy")
  createdShiftGenerationBatches ShiftGenerationBatch[] @relation("ShiftGenerationBatchCreatedBy")
  cancelledShifts Shift[] @relation("ShiftCancelledBy")
  approvedShifts Shift[] @relation("ShiftApprovedBy")
  additionalTimeApprovedShifts Shift[] @relation("ShiftAdditionalTimeApprovedBy")
  requestedCorrections CorrectionRequest[] @relation("CorrectionRequestedBy")
  reviewedCorrections CorrectionRequest[] @relation("CorrectionReviewedBy")
  appliedCorrections CorrectionRequest[] @relation("CorrectionAppliedBy")
  appliedPunchCorrections PunchCorrection[] @relation("PunchCorrectionAppliedBy")
  closedWeeklyPeriods WeeklyPeriod[] @relation("WeeklyPeriodClosedBy")
  reopenedWeeklyPeriods WeeklyPeriod[] @relation("WeeklyPeriodReopenedBy")
  weeklyCloseSnapshots WeeklyCloseSnapshot[] @relation("WeeklyCloseSnapshotCreatedBy")
  workOrderStatusHistoryEntries WorkOrderStatusHistory[] @relation("WorkOrderStatusHistoryCreatedBy")
  workOrderAssignmentsAssigned WorkOrderAssignment[] @relation("WorkOrderAssignmentAssignedBy")
  workOrderAssignmentsUnassigned WorkOrderAssignment[] @relation("WorkOrderAssignmentUnassignedBy")
  vehicleResponsibilityLogEntries VehicleResponsibilityLog[] @relation("VehicleResponsibilityLogActor")
  voidedServiceCompletions ServiceCompletion[] @relation("ServiceCompletionVoidedBy")
  issuedClientInvoices ClientInvoice[] @relation("ClientInvoiceIssuedBy")
  voidedClientInvoices ClientInvoice[] @relation("ClientInvoiceVoidedBy")
  sentClientInvoiceDeliveries ClientInvoiceDelivery[] @relation("ClientInvoiceDeliverySentBy")
  passwordResetTokens       PasswordResetToken[]

  @@map("users")
}

model Session {
  id              String    @id @default(cuid())
  userId          String
  tokenHash       String    @unique
  activeCompanyId String?
  expiresAt       DateTime
  revokedAt       DateTime?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeCompany   Company?  @relation(fields: [activeCompanyId], references: [id], onDelete: SetNull)

  @@index([userId], map: "sessions_user_id_idx")
  @@index([expiresAt], map: "sessions_expires_at_idx")
  @@index([activeCompanyId], map: "sessions_active_company_id_idx")
  @@map("sessions")
}

model GroupMembership {
  id         String           @id @default(cuid())
  groupId    String
  userId     String?
  email      String
  role       GroupRole
  status     MembershipStatus @default(INVITED)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  group      Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user       User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  invitations Invitation[]

  @@index([groupId], map: "group_memberships_group_id_idx")
  @@index([userId], map: "group_memberships_user_id_idx")
  @@unique([groupId, email], map: "group_memberships_group_id_email_key")
  @@map("group_memberships")
}

model CompanyMembership {
  id         String           @id @default(cuid())
  companyId  String
  userId     String?
  email      String
  role       CompanyRole
  status     MembershipStatus @default(INVITED)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  company    Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user       User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  invitations Invitation[]

  @@index([companyId], map: "company_memberships_company_id_idx")
  @@index([userId], map: "company_memberships_user_id_idx")
  @@unique([companyId, email], map: "company_memberships_company_id_email_key")
  @@map("company_memberships")
}

model Invitation {
  id                  String             @id @default(cuid())
  tokenHash           String             @unique
  invitedEmail        String
  expiresAt           DateTime
  consumedAt          DateTime?
  revokedAt           DateTime?
  kind                InvitationKind     @default(ONBOARDING)
  createdByUserId     String
  userId              String?
  groupId             String?
  companyId           String?
  groupMembershipId   String?
  companyMembershipId String?
  createdAt           DateTime           @default(now())
  createdBy           User               @relation("InvitationCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  user                User?              @relation("InvitationUser", fields: [userId], references: [id], onDelete: SetNull)
  group               Group?             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  company             Company?           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  groupMembership     GroupMembership?   @relation(fields: [groupMembershipId], references: [id], onDelete: Cascade)
  companyMembership   CompanyMembership? @relation(fields: [companyMembershipId], references: [id], onDelete: Cascade)

  @@index([invitedEmail], map: "invitations_invited_email_idx")
  @@index([expiresAt], map: "invitations_expires_at_idx")
  @@index([companyId], map: "invitations_company_id_idx")
  @@index([kind], map: "invitations_kind_idx")
  @@map("invitations")
}

model PasswordResetToken {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  requestedAt DateTime  @default(now())
  requesterIp String?
  userAgent   String?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "password_reset_tokens_user_id_idx")
  @@index([expiresAt], map: "password_reset_tokens_expires_at_idx")
  @@map("password_reset_tokens")
}

model AuditEvent {
  id          String   @id @default(cuid())
  actorUserId String
  action      String
  targetType  String
  targetId    String
  reason      String?
  metadata    Json?
  groupId     String?
  companyId   String?
  createdAt   DateTime @default(now())
  actor       User     @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  group       Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([actorUserId], map: "audit_events_actor_user_id_idx")
  @@index([groupId], map: "audit_events_group_id_idx")
  @@index([companyId], map: "audit_events_company_id_idx")
  @@index([createdAt], map: "audit_events_created_at_idx")
  @@map("audit_events")
}

model ServiceClient {
  id          String   @id @default(cuid())
  groupId     String
  companyId   String
  name        String
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Restrict)
  locations   Location[]
  laborRates  ClientLaborRate[]
  shifts      Shift[]
  scheduleTemplates ScheduleTemplate[]

  vehicles      Vehicle[]
  workOrders    WorkOrder[]
  clientInvoices ClientInvoice[]
  laborWorkAssignments LaborWorkAssignment[]

  @@index([groupId], map: "service_clients_group_id_idx")
  @@index([companyId], map: "service_clients_company_id_idx")
  @@index([archivedAt], map: "service_clients_archived_at_idx")
  @@unique([companyId, name], map: "service_clients_company_id_name_key")
  @@map("service_clients")
}

model Location {
  id          String   @id @default(cuid())
  groupId     String
  companyId   String
  serviceClientId String
  name        String
  timezone    String
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Restrict)
  serviceClient ServiceClient @relation(fields: [serviceClientId], references: [id], onDelete: Restrict)
  laborRates  ClientLaborRate[]
  supervisorAssignments SupervisorLocationAssignment[]
  shifts      Shift[]
  scheduleTemplates ScheduleTemplate[]
  kiosk       Kiosk?
  correctionRequests CorrectionRequest[]

  vehicles      Vehicle[]
  workOrders    WorkOrder[]
  workerScanEvents WorkerScanEvent[]
  laborWorkAssignments LaborWorkAssignment[]

  @@index([groupId], map: "locations_group_id_idx")
  @@index([companyId], map: "locations_company_id_idx")
  @@index([serviceClientId], map: "locations_service_client_id_idx")
  @@index([archivedAt], map: "locations_archived_at_idx")
  @@unique([companyId, name], map: "locations_company_id_name_key")
  @@map("locations")
}

model Employee {
  id          String   @id @default(cuid())
  groupId     String
  companyId   String
  fullName    String
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Restrict)
  rates       EmployeeRate[]
  pinCredentials EmployeePinCredential[]
  shifts      Shift[]
  scheduleTemplates ScheduleTemplate[]
  punchEvents PunchEvent[]
  correctionRequests CorrectionRequest[]
  workOrderAssignments WorkOrderAssignment[]
  vehicleResponsibilityLogs VehicleResponsibilityLog[]
  workerScanEvents WorkerScanEvent[]
  serviceCompletions ServiceCompletion[]
  laborWorkAssignments LaborWorkAssignment[]

  @@index([groupId], map: "employees_group_id_idx")
  @@index([companyId], map: "employees_company_id_idx")
  @@index([archivedAt], map: "employees_archived_at_idx")
  @@unique([companyId, fullName], map: "employees_company_id_full_name_key")
  @@map("employees")
}

model EmployeePinCredential {
  id          String   @id @default(cuid())
  employeeId  String
  companyId   String
  pinHash     String
  revokedAt   DateTime?
  createdByUserId String
  createdAt   DateTime @default(now())
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  createdBy   User     @relation("EmployeePinCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([employeeId], map: "employee_pin_credentials_employee_id_idx")
  @@index([companyId], map: "employee_pin_credentials_company_id_idx")
  @@index([revokedAt], map: "employee_pin_credentials_revoked_at_idx")
  @@map("employee_pin_credentials")
}

model EmployeeRate {
  id             String   @id @default(cuid())
  employeeId     String
  companyId      String
  rateMinorUnits Int
  currencyCode   String   @default("USD")
  effectiveStart DateTime
  effectiveEnd   DateTime?
  createdByUserId String
  createdAt      DateTime @default(now())
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  createdBy      User     @relation("EmployeeRateCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([employeeId], map: "employee_rates_employee_id_idx")
  @@index([companyId], map: "employee_rates_company_id_idx")
  @@index([effectiveStart], map: "employee_rates_effective_start_idx")
  @@map("employee_rates")
}

model ClientLaborRate {
  id             String   @id @default(cuid())
  companyId      String
  serviceClientId String?
  locationId     String?
  rateMinorUnits Int
  currencyCode   String   @default("USD")
  effectiveStart DateTime
  effectiveEnd   DateTime?
  createdByUserId String
  createdAt      DateTime @default(now())
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  serviceClient  ServiceClient? @relation(fields: [serviceClientId], references: [id], onDelete: Restrict)
  location       Location? @relation(fields: [locationId], references: [id], onDelete: Restrict)
  createdBy      User     @relation("ClientLaborRateCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([companyId], map: "client_labor_rates_company_id_idx")
  @@index([serviceClientId], map: "client_labor_rates_service_client_id_idx")
  @@index([locationId], map: "client_labor_rates_location_id_idx")
  @@index([effectiveStart], map: "client_labor_rates_effective_start_idx")
  @@map("client_labor_rates")
}

model SupervisorLocationAssignment {
  id               String   @id @default(cuid())
  groupId          String
  companyId        String
  locationId       String
  supervisorUserId String
  assignedByUserId String
  assignedAt       DateTime @default(now())
  unassignedAt     DateTime?
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  group            Group    @relation(fields: [groupId], references: [id], onDelete: Restrict)
  location         Location @relation(fields: [locationId], references: [id], onDelete: Restrict)
  supervisor       User     @relation("LocationSupervisor", fields: [supervisorUserId], references: [id], onDelete: Restrict)
  assignedBy       User     @relation("SupervisorAssignedBy", fields: [assignedByUserId], references: [id], onDelete: Restrict)

  @@index([groupId], map: "supervisor_location_assignments_group_id_idx")
  @@index([companyId], map: "supervisor_location_assignments_company_id_idx")
  @@index([locationId], map: "supervisor_location_assignments_location_id_idx")
  @@index([supervisorUserId], map: "supervisor_location_assignments_supervisor_user_id_idx")
  @@index([unassignedAt], map: "supervisor_location_assignments_unassigned_at_idx")
  @@map("supervisor_location_assignments")
}

model ScheduleTemplate {
  id             String   @id @default(cuid())
  groupId        String
  companyId      String
  locationId     String
  employeeId     String
  serviceClientId String
  name           String
  daysOfWeek     Int[]
  localStartTime String
  localEndTime   String
  timezone       String
  startsOnDate   DateTime
  endsOnDate     DateTime?
  archivedAt     DateTime?
  createdByUserId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  group          Group    @relation(fields: [groupId], references: [id], onDelete: Restrict)
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  location       Location @relation(fields: [locationId], references: [id], onDelete: Restrict)
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  serviceClient  ServiceClient @relation(fields: [serviceClientId], references: [id], onDelete: Restrict)
  createdBy      User     @relation("ScheduleTemplateCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  generationBatches ShiftGenerationBatch[]

  @@index([groupId], map: "schedule_templates_group_id_idx")
  @@index([companyId], map: "schedule_templates_company_id_idx")
  @@index([locationId], map: "schedule_templates_location_id_idx")
  @@index([employeeId], map: "schedule_templates_employee_id_idx")
  @@index([archivedAt], map: "schedule_templates_archived_at_idx")
  @@map("schedule_templates")
}

model ShiftGenerationBatch {
  id              String   @id @default(cuid())
  groupId         String
  companyId       String
  operationType   ShiftBatchType
  operationKey    String   @unique
  sourceTemplateId String?
  sourceWeekStartUtc DateTime?
  targetWeekStartUtc DateTime?
  createdByUserId String
  createdAt       DateTime @default(now())
  group           Group    @relation(fields: [groupId], references: [id], onDelete: Restrict)
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  sourceTemplate  ScheduleTemplate? @relation(fields: [sourceTemplateId], references: [id], onDelete: SetNull)
  createdBy       User     @relation("ShiftGenerationBatchCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  shifts          Shift[]

  @@index([groupId], map: "shift_generation_batches_group_id_idx")
  @@index([companyId], map: "shift_generation_batches_company_id_idx")
  @@index([sourceTemplateId], map: "shift_generation_batches_source_template_id_idx")
  @@map("shift_generation_batches")
}

model Shift {
  id              String   @id @default(cuid())
  groupId         String
  companyId       String
  locationId      String
  employeeId      String
  serviceClientId String
  status          ShiftStatus @default(SCHEDULED)
  scheduledStartUtc DateTime
  scheduledEndUtc DateTime
  timezone        String
  cancelledAt     DateTime?
  cancelledByUserId String?
  cancelReason    String?
  approvedAt      DateTime?
  approvedByUserId String?
  additionalTimeApprovedAt DateTime?
  additionalTimeApprovedByUserId String?
  generationBatchId String?
  planningKey     String? @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  group           Group    @relation(fields: [groupId], references: [id], onDelete: Restrict)
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  location        Location @relation(fields: [locationId], references: [id], onDelete: Restrict)
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  serviceClient   ServiceClient @relation(fields: [serviceClientId], references: [id], onDelete: Restrict)
  cancelledBy     User?    @relation("ShiftCancelledBy", fields: [cancelledByUserId], references: [id], onDelete: SetNull)
  approvedBy      User?    @relation("ShiftApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  additionalTimeApprovedBy User? @relation("ShiftAdditionalTimeApprovedBy", fields: [additionalTimeApprovedByUserId], references: [id], onDelete: SetNull)
  generationBatch ShiftGenerationBatch? @relation(fields: [generationBatchId], references: [id], onDelete: SetNull)
  punchEvents     PunchEvent[]
  correctionRequests CorrectionRequest[]
  punchCorrections PunchCorrection[]
  laborWorkAssignments LaborWorkAssignment[]

  @@index([groupId], map: "shifts_group_id_idx")
  @@index([companyId], map: "shifts_company_id_idx")
  @@index([locationId], map: "shifts_location_id_idx")
  @@index([employeeId], map: "shifts_employee_id_idx")
  @@index([scheduledStartUtc], map: "shifts_scheduled_start_utc_idx")
  @@index([scheduledEndUtc], map: "shifts_scheduled_end_utc_idx")
  @@index([status], map: "shifts_status_idx")
  @@index([generationBatchId], map: "shifts_generation_batch_id_idx")
  @@index([approvedAt], map: "shifts_approved_at_idx")
  @@map("shifts")
}

model Kiosk {
  id         String   @id @default(cuid())
  groupId    String
  companyId  String
  locationId String   @unique
  name       String
  archivedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Restrict)
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Restrict)
  credential KioskCredential?
  punchEvents PunchEvent[]

  @@index([groupId], map: "kiosks_group_id_idx")
  @@index([companyId], map: "kiosks_company_id_idx")
  @@map("kiosks")
}

model KioskCredential {
  id         String   @id @default(cuid())
  kioskId    String   @unique
  secretHash String
  createdAt  DateTime @default(now())
  revokedAt  DateTime?
  kiosk      Kiosk    @relation(fields: [kioskId], references: [id], onDelete: Restrict)

  @@map("kiosk_credentials")
}

model PunchEvent {
  id                String      @id @default(cuid())
  groupId           String
  companyId         String
  shiftId           String
  employeeId        String
  kioskId           String
  action            PunchAction
  eventUtc          DateTime
  serverReceivedUtc DateTime    @default(now())
  idempotencyKey    String      @unique
  deviceEventId     String?
  deviceTimestamp   DateTime?
  sequence          Int?
  isLate            Boolean     @default(false)
  isEarly           Boolean     @default(false)
  breakMinutes      Int?
  group             Group       @relation(fields: [groupId], references: [id], onDelete: Restrict)
  company           Company     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  shift             Shift       @relation(fields: [shiftId], references: [id], onDelete: Restrict)
  employee          Employee    @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  kiosk             Kiosk       @relation(fields: [kioskId], references: [id], onDelete: Restrict)
  punchCorrections  PunchCorrection[]

  @@index([shiftId], map: "punch_events_shift_id_idx")
  @@index([employeeId], map: "punch_events_employee_id_idx")
  @@index([kioskId], map: "punch_events_kiosk_id_idx")
  @@index([eventUtc], map: "punch_events_event_utc_idx")
  @@map("punch_events")
}

model CorrectionRequest {
  id                   String            @id @default(cuid())
  groupId              String
  companyId            String
  shiftId              String
  employeeId           String
  locationId           String
  type                 CorrectionType
  status               CorrectionStatus  @default(PENDING)
  reason               String
  originalPayload      Json
  proposedPayload      Json
  finalPayload         Json?
  requestedByUserId    String?
  requestedByEmployeeId String?
  reviewedByUserId     String?
  reviewedAt           DateTime?
  reviewReason         String?
  appliedAt            DateTime?
  appliedByUserId      String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  group                Group             @relation(fields: [groupId], references: [id], onDelete: Restrict)
