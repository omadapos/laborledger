# LaborLedger — production environment EXAMPLE (VPS: PM2 + Nginx, no Docker)
#
# Copy on the VPS only (never commit the real file):
#   cp .env.production.example .env.production
#   nano .env.production
#
# Target host: admin.mariosautodetail.com
# App root:     /home/ubuntu/apps/laborledger
# Legacy app:   /home/ubuntu/apps/servihour  (leave running until cutover)

NODE_ENV=production

# ---------------------------------------------------------------------------
# Database (PostgreSQL on the VPS — existing data, no reset)
# ---------------------------------------------------------------------------
# If you kept the database created for ServiHour, the DB name may still be
# "servihour". Use the REAL database name and credentials from the VPS:
#
#   DATABASE_URL="postgresql://servihour:YOUR_PASSWORD@localhost:5432/servihour?schema=public"
#
# Only change the database name when you intentionally create a new one.
DATABASE_URL="postgresql://servihour:CHANGE_ME@localhost:5432/servihour?schema=public"

# NOTE: Admin sessions use opaque DB-backed tokens (httpOnly cookie
# "laborledger.sid"). There is NO SESSION_SECRET or JWT_SECRET to set.
# Cookies are issued Secure + SameSite=Lax — HTTPS is required in production.

# ---------------------------------------------------------------------------
# Platform superadmin (synced into the DB by the API on startup)
# ---------------------------------------------------------------------------
PLATFORM_SUPERADMIN_EMAIL=superadmin@mariosautodetail.com
PLATFORM_SUPERADMIN_PASSWORD=change-me-rotate-after-first-login
PLATFORM_SUPERADMIN_NAME=Platform Superadmin

# ---------------------------------------------------------------------------
# Internal API URL (Admin + Field BFF — server-side only, not public)
# ---------------------------------------------------------------------------
API_BASE_URL="http://127.0.0.1:4000"

# ---------------------------------------------------------------------------
# Admin UI (Next.js)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="LaborLedger"
# Used in password-reset and invitation email links:
ADMIN_APP_URL="https://admin.mariosautodetail.com"

# ---------------------------------------------------------------------------
# Field employee PWA (apps/field on port 3001)
# ---------------------------------------------------------------------------
# Required: signs Field employee session cookies (httpOnly, server-side only).
FIELD_SESSION_SECRET=change-me-long-random-field-session-secret

# Default company for PIN login and worker BFF routes (UUID from admin).
WORKER_COMPANY_ID=

# Location credentials for clock punches (from admin > Kiosks).
KIOSK_ID=
KIOSK_SECRET=

# Optional: separate public Field hostname later (requires Nginx + DNS).
# FIELD_PUBLIC_URL=https://field.mariosautodetail.com

# ---------------------------------------------------------------------------
# VIN decode adapter
# ---------------------------------------------------------------------------
VIN_DECODER=nhtsa
NHTSA_VPIC_BASE_URL=https://vpic.nhtsa.dot.gov/api
NHTSA_VPIC_TIMEOUT_MS=5000

# ---------------------------------------------------------------------------
# Email delivery (invoices, password reset, invitations)
# ---------------------------------------------------------------------------
# console = log only (no real email)
# resend  = send via Resend (verified sender domain required)
EMAIL_PROVIDER=resend
RESEND_API_KEY=change-me-resend-api-key

INVOICE_FROM_EMAIL=billing@mariosautodetail.com
INVOICE_FROM_NAME=LaborLedger Billing
AUTH_FROM_EMAIL=no-reply@mariosautodetail.com
AUTH_FROM_NAME=LaborLedger

# ---------------------------------------------------------------------------
# PM2 process ports (set in ecosystem.config.cjs — reference only)
# ---------------------------------------------------------------------------
# API   -> 4000 (localhost)
# Admin -> 3000 (Nginx -> admin.mariosautodetail.com)
# Field -> 3001 (optional public subdomain later)

# ---------------------------------------------------------------------------
# Flutter / future mobile API access
# ---------------------------------------------------------------------------
# Keep API on localhost for now. Admin BFF handles web auth.
# When Flutter needs direct API access, expose api.mariosautodetail.com
# with TLS and add auth endpoints — do not expose Postgres or admin ports.
