{
  "name": "laborledger",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --parallel --filter @laborledger/admin --filter @laborledger/field --filter @laborledger/api dev",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "db:generate": "node scripts/with-db-url.mjs pnpm --filter @laborledger/database db:generate",
    "db:migrate": "node scripts/with-db-url.mjs pnpm --filter @laborledger/database db:migrate:deploy",
    "db:validate": "node scripts/with-db-url.mjs pnpm --filter @laborledger/database db:validate",
    "seed:demo": "node scripts/with-db-url.mjs pnpm --filter @laborledger/database seed:demo"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^15.5.19",
    "@eslint/js": "^9.30.1",
    "eslint": "^9.30.1",
    "globals": "^16.3.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.36.0"
  }
}
